#pragma once

#include <QObject>

class QGraphicsScene;
class QEvent;

class SceneController :
    public QObject
{
    Q_OBJECT

public:

    explicit SceneController(
        QGraphicsScene* scene
    );


    ~SceneController() = default;


    SceneController(
        const SceneController&
    ) = delete;


    SceneController& operator=(
        const SceneController&
    ) = delete;


signals:

    void sceneClicked(
        double x,
        double y
    );


protected:

    bool eventFilter(
        QObject* watched,
        QEvent* event
    ) override;


private:

    QGraphicsScene* scene =
        nullptr;
};
